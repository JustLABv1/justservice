{
  "name": "next-monorepo",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "build": "pnpm --dir apps/web build",
    "build:api": "go -C apps/api build -o apps/api/bin/server ./cmd/server",
    "dev": "pnpm --dir apps/web dev",
    "dev:api": "go -C apps/api run ./cmd/server",
    "lint": "pnpm --dir apps/web lint",
    "format": "pnpm --dir apps/web format",
    "typecheck": "pnpm --dir apps/web typecheck"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
